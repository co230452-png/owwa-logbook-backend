# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/owwa_logbook?retryWrites=true&w=majority&appName=Cluster0

# JWT Secret Key - Use a long random string
JWT_SECRET=your_super_secret_jwt_key_here

# JWT Token Expiry
JWT_EXPIRES_IN=7d

# Server Port (Railway sets this automatically, leave as 5000 for local)
PORT=5000

# Frontend URL - for local use http://localhost:5173
# For production use your Railway frontend URL e.g. https://owwa-frontend.up.railway.app
FRONTEND_URL=http://localhost:5173

# Node Environment
NODE_ENV=development
